var tıklamaHızı = 26; //
var otoTıkla = setInterval(function() {
    var butonlar = document.querySelectorAll('.activityButtonText__8af73');
    butonlar.forEach(function(buton) {
        if (buton.innerText === "Macera") {
   
            buton.click();
            buton.dispatchEvent(new MouseEvent('mousedown', {bubbles: true}));
            buton.dispatchEvent(new MouseEvent('mouseup', {bubbles: true}));
        }
    });
}, tıklamaHızı);
